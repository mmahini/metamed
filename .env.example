# Root-level .env.example — copy to backend/.env for local dev
# See backend/.env.example for the full list

# Django
DJANGO_SECRET_KEY=dev-insecure-secret-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

# MySQL (matches docker-compose.yml service "db")
MYSQL_DATABASE=metamed
MYSQL_USER=metamed
MYSQL_PASSWORD=metamed
MYSQL_HOST=db
MYSQL_PORT=3306

# CORS — frontend dev server
CORS_ALLOWED_ORIGINS=http://localhost:5175,http://127.0.0.1:5175

# Email via Resend (leave blank to skip sending in dev)
RESEND_API_KEY=
RESEND_FROM=متامد <noreply@metamed.ir>

# Return OTP code in API response (dev only, never in production)
OTP_EXPOSE_DEV_CODE=1
