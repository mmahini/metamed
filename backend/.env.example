DJANGO_SECRET_KEY=dev-insecure-secret-change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=*

MYSQL_DATABASE=metamed
MYSQL_USER=metamed
MYSQL_PASSWORD=metamed
MYSQL_HOST=db
MYSQL_PORT=3306

CORS_ALLOWED_ORIGINS=http://localhost:5175,http://127.0.0.1:5175

# Resend (transactional email — OTP codes)
# Leave blank in dev: OTP code is returned in the API response.
RESEND_API_KEY=
RESEND_FROM=متامد <noreply@metamed.ir>

# Set to 0 in production to hide OTP from API responses
OTP_EXPOSE_DEV_CODE=1
